# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/arxiv_search

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-min-32-chars

# AI Provider Settings
# AI_PROVIDER: anthropic | openai | gemini | local  (default: anthropic)
# AI_MODEL: model name — defaults per provider:
#   anthropic → claude-sonnet-4-20250514
#   openai    → gpt-4o
#   gemini    → gemini-2.0-flash
#   local     → llama3
# AI_API_KEY: API key (for anthropic, can also use ANTHROPIC_API_KEY)
# AI_BASE_URL: custom base URL — required for local (e.g. http://localhost:11434/v1)
#              optional override for other providers

AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514
AI_API_KEY=sk-ant-xxxxx
# AI_BASE_URL=http://localhost:11434/v1

# (Legacy) Anthropic-specific key — used if AI_API_KEY is not set
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxx

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@arxiv-search.com

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CRON_SECRET=your-cron-secret-min-32-chars

# Admin seed password (REQUIRED for prisma db seed - change this!)
ADMIN_SEED_PASSWORD=change-me-before-running-seed
